# Environment variables for Agocare Health production
# Copy this to /var/www/agocare/.env and fill in the values
# DO NOT commit this file with real values to Git!

# PostgreSQL
DB_PASSWORD=your_strong_database_password_here

# JWT Secret (minimum 32 characters, use a random string)
JWT_SECRET=your_super_secret_jwt_key_change_this_minimum_32_chars

# Server
SERVER_PORT=8080
SPRING_PROFILES_ACTIVE=prod

# Domain
DOMAIN=agocare.com
