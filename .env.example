# ========================================
# AGOCARE SOCIAL AUTH CONFIGURATION
# ========================================
# Copy this file to .env and fill in your credentials
# Never commit .env to version control!

# ========== DATABASE ==========
DB_HOST=localhost
DB_PORT=5432
DB_NAME=agrocare_db
DB_USERNAME=postgres
DB_PASSWORD=Uttorent@24

# ========== MONGODB ==========
MONGO_HOST=localhost
MONGO_PORT=27017
MONGO_DB=agrocare_nosql

# ========== JWT ==========
JWT_SECRET=your_super_secret_key_change_this_in_production_environment_12345
JWT_EXPIRATION=86400000

# ========== APP CONFIG ==========
APP_BASE_URL=http://localhost:8080

# ========== GOOGLE OAUTH2 ==========
# Get these from: https://console.cloud.google.com/
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:8080/api/auth/oauth/google/callback

# ========== FACEBOOK OAUTH2 ==========
# Get these from: https://developers.facebook.com/
FACEBOOK_APP_ID=your_facebook_app_id
FACEBOOK_APP_SECRET=your_facebook_app_secret
FACEBOOK_REDIRECT_URI=http://localhost:8080/api/auth/oauth/facebook/callback

# ========== APPLE SIGN IN ==========
# Get these from: https://developer.apple.com/
APPLE_CLIENT_ID=your_apple_service_id
APPLE_KEY_ID=your_apple_key_id
APPLE_TEAM_ID=your_apple_team_id
APPLE_REDIRECT_URI=http://localhost:8080/api/auth/oauth/apple/callback
# Note: You'll also need to generate a private key in Apple Developer Portal
# and convert it to base64 for the APPLE_PRIVATE_KEY environment variable

# ========== SERVER ==========
SERVER_PORT=8080

# ========== LOGGING ==========
LOG_LEVEL=INFO
